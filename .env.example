# All variables are optional — sensible defaults are baked in.
# Copy this file to .env only if you need to override something.

# ---- Per-user settings (when multiple people share one host) ---------------
# Each user must pick a unique port. Docker Compose itself isolates volumes
# and containers per $USER via the `name:` field in docker-compose.yml.
CEREBRO_PORT=8000

# Bind address. "127.0.0.1" = localhost only (default, safe for shared hosts).
# Set "0.0.0.0" to expose on the LAN/public — pair with a TLS reverse proxy.
CEREBRO_BIND=127.0.0.1

# ---- Auth ------------------------------------------------------------------
# Leave empty: the master generates a random 43-char token into /data/token on
# first boot. Retrieve with: docker compose exec cerebro-server cerebro-server token
# Set only if you want to pin a specific value (e.g. to share across deployments).
CEREBRO_TOKEN=

# ---- Public deployment (behind TLS) ----------------------------------------
# Comma-separated list of allowed browser Origins for WebSocket upgrades.
# Leave empty on a trusted LAN; set when going public:
#   CEREBRO_ALLOWED_ORIGINS=https://cerebro.example.com
CEREBRO_ALLOWED_ORIGINS=

# WebAuthn relying-party id — usually auto-detected from Host/X-Forwarded-Host.
# Override only if your proxy mangles those, e.g.:
#   CEREBRO_RP_ID=cerebro.example.com
CEREBRO_RP_ID=

# ---- Misc ------------------------------------------------------------------
LOG_LEVEL=INFO
