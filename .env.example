# Optional — leave empty and the master generates one on first boot,
# persisted to /data/token (Docker volume).
# Retrieve it any time with: docker compose exec cerebro-server cerebro-server token
# Set only if you want to override the generated value (e.g. to share a token across deployments).
CEREBRO_TOKEN=

# Optional: server log level (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO
